// See https://zed.dev/docs/configuring-zed.
{
  "auto_update": true,
  "autosave": "on_focus_change",
  "buffer_font_family": "SF Mono",
  "buffer_font_features": {
    "calt": false,
    "zero": true,
  },
  "buffer_font_size": 10,
  "disable_ai": true,
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "languages": {
    "C": {
      "enable_language_server": false,
    },
    "C++": {
      "enable_language_server": false,
    },
  },
  "max_tabs": 1,
  "relative_line_numbers": "enabled",
  "show_completions_on_input": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "tab_size": 2,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "dock": "right",
  },
  "theme": {
    "mode": "system",
    "dark": "One Dark",
    "light": "One Light",
  },
  "ui_font_size": 13,
  "vim_mode": true,
  "wrap_guides": [72, 80, 100],
}
